    private async Task PeerSelectionChanged(SelectionEvent evt)
    {
        if (DiagramInstance?.SelectionSettings != null && evt != null && !string.IsNullOrEmpty(evt.UserId) && evt.ElementIds?.Count > 0)
        {
            _peerSelections[evt.ConnectionId] = (evt.UserName ?? string.Empty, evt.ElementIds?.ToHashSet() ?? new(), evt.SelectorBounds!);
            foreach (var (key, peer) in _peerSelections)
            {
                if (key == evt.ConnectionId) continue;
                if (peer.NodeIds != null && peer.NodeIds.SetEquals(evt.ElementIds!))
                {
                    if (!IsEqual(peer.selectorBounds.Bounds!, evt.SelectorBounds?.Bounds!) || peer.selectorBounds.RotationAngle != evt.SelectorBounds?.RotationAngle)
                    {
                        _peerSelections[key] = (peer!.UserName, peer!.NodeIds, evt?.SelectorBounds!);
                    }
                }
            }

            foreach (var (key, peer) in _peerSelections)
            {
                if (key == evt?.ConnectionId)
                    continue;

                if (peer.NodeIds == null || peer.NodeIds.Count == 0)
                    continue;

                bool hasOverlap = false;

                foreach (var id in peer.NodeIds)
                {
                    IDiagramObject? obj = DiagramInstance?.GetObject(id);
                    if (obj == null)
                        continue;

                    if (obj is Connector)
                    {
                        hasOverlap = true;
                        break;
                    }
                    if (evt!.ElementIds!.Contains(id))
                    {
                        hasOverlap = true;
                        break;
                    }
                }

                if (!hasOverlap)
                    continue;

                SelectorBounds computedBounds = CalculateSelectorBounds(peer.NodeIds, evt!.SelectorBounds?.RotationAngle ?? 0);

                if (!IsEqual(peer.selectorBounds.Bounds!, computedBounds.Bounds!) ||
                    peer.selectorBounds.RotationAngle != computedBounds.RotationAngle)
                {
                    _peerSelections[key] =
                        (peer.UserName, peer.NodeIds, computedBounds);
                }
            }
        }
    }

    private SelectorBounds CalculateSelectorBounds(HashSet<string> nodeIds, double rotationAngle)
    {
        double minLeft = double.PositiveInfinity;
        double minTop = double.PositiveInfinity;
        double maxRight = double.NegativeInfinity;
        double maxBottom = double.NegativeInfinity;

        foreach (var elementId in nodeIds)
        {
            var obj = DiagramInstance?.GetObject(elementId);
            if (obj == null)
                continue;

            if (obj is Node node)
            {
                double nx = node.OffsetX;
                double ny = node.OffsetY;
                double w = node.Width ?? 0;
                double h = node.Height ?? 0;

                double left = nx - w / 2;
                double top = ny - h / 2;
                double right = nx + w / 2;
                double bottom = ny + h / 2;

                minLeft = Math.Min(minLeft, left);
                minTop = Math.Min(minTop, top);
                maxRight = Math.Max(maxRight, right);
                maxBottom = Math.Max(maxBottom, bottom);
            }
            else if (obj is Connector connector)
            {
                DiagramPoint?[] pts = new[] { connector.SourcePoint, connector.TargetPoint };

                foreach (DiagramPoint pt in pts)
                {
                    if (pt == null) continue;

                    minLeft = Math.Min(minLeft, pt.X);
                    minTop = Math.Min(minTop, pt.Y);
                    maxRight = Math.Max(maxRight, pt.X);
                    maxBottom = Math.Max(maxBottom, pt.Y);
                }
            }
        }

        if (double.IsPositiveInfinity(minLeft) || double.IsNegativeInfinity(maxRight))
            return default!;

        double width = Math.Max(0, maxRight - minLeft);
        double height = Math.Max(0, maxBottom - minTop);

        return new SelectorBounds
        {
            Bounds = new DiagramRect
            {
                X = minLeft + width / 2,
                Y = minTop + height / 2,
                Width = width,
                Height = height
            },
            RotationAngle = rotationAngle
        };
    }

    private string GetUserColor(string userName)
    {
        string[] colors = new string[] { "#3b82f6", "#ef4444", "#10b981", "#f59e0b", "#8b5cf6", "#ec4899", "#6366f1", "#14b8a6", "#f97316", "#06b6d4" };
        if (int.TryParse(userName, out int userId))
        {
            return colors[userId % colors.Length];
        }
        else if(!string.IsNullOrEmpty(userName))
        {
            return colors[Math.Abs(userName.GetHashCode()) % colors.Length];
        }
        return colors[0];
    }
