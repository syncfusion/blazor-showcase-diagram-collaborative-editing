    private DiagramRect CalculateConnectorBounds(Connector connector)
    {
        double minX = Math.Min(connector.SourcePoint!.X, connector.TargetPoint!.X);
        double minY = Math.Min(connector.SourcePoint.Y, connector.TargetPoint.Y);
        double width = Math.Abs(connector.TargetPoint.X - connector.SourcePoint.X);
        double height = Math.Abs(connector.TargetPoint.Y - connector.SourcePoint.Y);

        return new DiagramRect()
        {
            X = minX + width / 2,
            Y = minY + height / 2,
            Width = width,
            Height = height
        };
    }

    private async Task<(List<string>, SelectorBounds)> UpdateOtherClientSelectorBounds()
    {
        DiagramSelectionSettings diagramSelectionSettings = DiagramInstance.SelectionSettings;
        HashSet<string> elementIds = new();
        SelectorBounds bounds = new();
        bool canRefresh = false;

        if (diagramSelectionSettings != null)
        {
            elementIds = GetSelectedIds(diagramSelectionSettings).ToHashSet();
            HashSet<string> editedSet = new HashSet<string>(editedElements);
            List<string> keysToRemove = new List<string>();
            if (isPropertyChanged)
            {
                if (diagramSelectionSettings.Nodes!.Count > 0)
                {
                    Node selectedNode = diagramSelectionSettings.Nodes[0];
                    bounds = new SelectorBounds()
                        {
                            Bounds = new DiagramRect() { X = selectedNode.OffsetX, Y = selectedNode.OffsetY, Width = (double)selectedNode!.Width!, Height = (double)selectedNode!.Height! },
                            RotationAngle = diagramSelectionSettings.Nodes[0].RotationAngle
                        };
                }
                else if (diagramSelectionSettings.Connectors.Count > 0)
                {
                    bounds = new SelectorBounds()
                        {
                            Bounds = CalculateConnectorBounds(diagramSelectionSettings.Connectors[0]),
                            RotationAngle = diagramSelectionSettings.RotationAngle
                        };
                }
                isPropertyChanged = false;
            }
            else
            {
                bounds = new SelectorBounds()
                    {
                        Bounds = new DiagramRect() { X = diagramSelectionSettings.OffsetX, Y = diagramSelectionSettings.OffsetY, Width = diagramSelectionSettings.Width, Height = diagramSelectionSettings.Height },
                        RotationAngle = diagramSelectionSettings.RotationAngle
                    };
            }
            foreach (KeyValuePair<string, (string UserName, HashSet<string> NodeIds, SelectorBounds selectorBounds)> kvp in _peerSelections.Where(p => p.Key != this.ConnectionId))
            {
                if (elementIds.Count == 0)
                {
                    List<string> commonIds = kvp.Value.NodeIds.Where(id => editedSet.Contains(id)).ToList();

                    if (commonIds.Count > 0)
                    {
                        foreach (string id in commonIds)
                        {
                            IDiagramObject? objectValue = DiagramInstance.GetObject(id);
                            if (objectValue == null)
                            {
                                kvp.Value.NodeIds.Remove(id);
                                canRefresh = true;
                            }
                        }

                        if (!kvp.Value.NodeIds.Any())
                        {
                            keysToRemove.Add(kvp.Key);
                            canRefresh = true;
                        }
                    }
                }
                else if (kvp.Value.NodeIds.SetEquals(elementIds))
                {
                    _peerSelections[kvp.Key] = (kvp.Value.UserName!, kvp.Value.NodeIds!, bounds);
                    canRefresh = true;
                }
                else if (kvp.Value.NodeIds != null && kvp.Value.NodeIds.Count > 0)
                {
                    bool isConnector = false;
                    string elementID = kvp.Value.NodeIds.FirstOrDefault()!;
                    SelectorBounds selectorBounds = UpdateSelectionHighlighter(diagramSelectionSettings, bounds, elementID, out isConnector);
                    if (isConnector)
                    {
                        _peerSelections[kvp.Key] = (kvp.Value.UserName!, kvp.Value.NodeIds, selectorBounds);
                        canRefresh = true;
                    }
                }
                if (kvp.Value.NodeIds!.Count > 1)
                {
                    SelectorBounds selectorBounds = CalculateSelectorBounds(kvp.Value.NodeIds, 0);
                    _peerSelections[kvp.Key] = (kvp.Value.UserName ?? string.Empty, kvp.Value.NodeIds, selectorBounds);
                    canRefresh = true;
                }
            }
            foreach (string key in keysToRemove)
            {
                _peerSelections.Remove(key);
            }
            if (canRefresh)
                await InvokeAsync(StateHasChanged);
        }
        return (elementIds.ToList(), bounds);
    }

    private SelectorBounds UpdateSelectionHighlighter( DiagramSelectionSettings diagramSelectionSettings,SelectorBounds selectorBounds,string elementID,out bool isConnector)
    {
        isConnector = false;

        if (diagramSelectionSettings != null && diagramSelectionSettings.Nodes != null && diagramSelectionSettings.Nodes.Count > 0 && !string.IsNullOrWhiteSpace(elementID))
        {
            Node currentNode = diagramSelectionSettings.Nodes[0];
            isConnector = currentNode!.InEdges!.Contains(elementID) || currentNode!.OutEdges!.Contains(elementID);

            if (isConnector)
            {
                Connector connector = (DiagramInstance.GetObject(elementID) as Connector)!;
                if (connector != null)
                {
                    selectorBounds = new SelectorBounds()
                    {
                        Bounds = CalculateConnectorBounds(connector),
                        RotationAngle = DiagramInstance!.SelectionSettings!.RotationAngle
                    };
                }
            }
        }
        return selectorBounds;
    }

    private async Task SendCurrentSelectorBoundsToOtherClient()
    {
        (List<string> elementIds, SelectorBounds bounds) = await UpdateOtherClientSelectorBounds();
        if (connection.State != HubConnectionState.Disconnected)
            await connection.InvokeAsync("SelectElements", elementIds, bounds, true);
    }
